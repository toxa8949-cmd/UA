generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  editor
  viewer
}

enum ContentStatus {
  draft
  published
  archived
}

enum CategoryType {
  article
  service
  deal
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(viewer)
  articles  Article[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Country {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  emoji              String?
  shortDescription   String?
  fullDescription    String?  @db.Text
  capital            String?
  currency           String?
  language           String?
  averageSalary      Int?
  minimumSalary      Int?
  averageRent        Int?
  costOfLivingIndex  Float?
  taxSummary         String?  @db.Text
  businessSummary    String?  @db.Text
  healthcareSummary  String?  @db.Text
  educationSummary   String?  @db.Text
  transportSummary   String?  @db.Text
  status             ContentStatus @default(published)
  seoTitle           String?
  seoDescription     String?
  articles           Article[]
  deals              Deal[]
  services           Service[] @relation("CountryServices")
  presets            CalculatorPreset[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
}

model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  type        CategoryType
  articles    Article[]
  services    Service[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([type])
}

model Article {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String        @db.Text
  coverImage     String?
  countryId      String?
  country        Country?      @relation(fields: [countryId], references: [id], onDelete: SetNull)
  categoryId     String?
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId       String?
  author         User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  status         ContentStatus @default(draft)
  readingTime    Int?
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  publishedAt    DateTime?
  updatedAt      DateTime      @updatedAt
  createdAt      DateTime      @default(now())

  @@index([status])
  @@index([countryId])
  @@index([categoryId])
  @@index([publishedAt])
}

model Service {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?       @db.Text
  logo           String?
  websiteUrl     String?
  affiliateUrl   String?
  categoryId     String?
  category       Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  countries      Country[]     @relation("CountryServices")
  pros           String[]
  cons           String[]
  rating         Float?
  pricingSummary String?
  isFeatured     Boolean       @default(false)
  status         ContentStatus @default(published)
  deals          Deal[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([isFeatured])
}

model Deal {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String?       @db.Text
  serviceId    String?
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  countryId    String?
  country      Country?      @relation(fields: [countryId], references: [id], onDelete: SetNull)
  affiliateUrl String?
  bonusAmount  String?
  terms        String?       @db.Text
  validUntil   DateTime?
  status       ContentStatus @default(published)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
}

model AffiliateClick {
  id          String   @id @default(cuid())
  serviceId   String?
  dealId      String?
  articleId   String?
  countryCode String?
  referrer    String?
  userAgent   String?
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([serviceId])
  @@index([dealId])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id              String   @id @default(cuid())
  email           String   @unique
  countryInterest String?
  source          String?
  createdAt       DateTime @default(now())
}

model CalculatorPreset {
  id        String   @id @default(cuid())
  type      String
  countryId String?
  country   Country? @relation(fields: [countryId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}
